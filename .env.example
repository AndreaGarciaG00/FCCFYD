# Copia este archivo a .env y rellena con tu proyecto en Supabase → Settings → API
VITE_SUPABASE_URL=https://TU_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_TU_CLAVE_PUBLICA

# Bucket de Storage (público) para fotos de docentes, CV, portadas, documentos de inscripción…
# Créalo en Supabase → Storage y políticas RLS para usuarios autenticados (admin).
VITE_SUPABASE_STORAGE_BUCKET=public-media
