# Referencia de API Supabase (sin secretos).
# En la app usa .env con VITE_SUPABASE_URL y VITE_SUPABASE_PUBLISHABLE_KEY.
# Sustituye $SUPABASE_URL, $ANON_KEY y $ACCESS_TOKEN en cada curl.

# LogIn - Iniciar sesión (equiv. supabase.auth.signInWithPassword)
# curl -X POST "$SUPABASE_URL/auth/v1/token?grant_type=password" \
#   -H "apikey: $ANON_KEY" -H "Content-Type: application/json" \
#   -d '{"email":"TU_CORREO","password":"TU_PASSWORD"}'

# LogOut (equiv. supabase.auth.signOut) — requiere Authorization: Bearer <access_token>
# curl -X POST "$SUPABASE_URL/auth/v1/logout" \
#   -H "apikey: $ANON_KEY" -H "Authorization: Bearer $ACCESS_TOKEN"

# GetUser (equiv. supabase.auth.getUser)
# curl -X GET "$SUPABASE_URL/auth/v1/user" \
#   -H "apikey: $ANON_KEY" -H "Authorization: Bearer $ACCESS_TOKEN"

